#include <iostream>
using namespace std;

class Game {
private:
    char board[3][3];
    char turn;     // 'X' or 'O'
    char winner;

public:
    // Constructor
    Game() {
        resetGame();
    }

    // Reset Game
    void resetGame() {
        for (int i = 0; i < 3; i++)
            for (int j = 0; j < 3; j++)
                board[i][j] = ' ';

        turn = 'X';
        winner = ' ';
    }

    // Print Board
    void printBoard() {
        cout << "\n";
        for (int i = 0; i < 3; i++) {
            cout << " ";
            for (int j = 0; j < 3; j++) {
                cout << board[i][j];
                if (j < 2) cout << " | ";
            }
            cout << "\n";
            if (i < 2) cout << "---|---|---\n";
        }
        cout << "\n";
    }

    // Make Move
    bool makeMove(int row, int col) {
        if (row < 0 || row > 2 || col < 0 || col > 2) {
            cout << "Invalid position!\n";
            return false;
        }

        if (board[row][col] != ' ') {
            cout << "Cell already taken!\n";
            return false;
        }

        board[row][col] = turn;
        return true;
    }

    // Switch Turn
    void switchTurn() {
        turn = (turn == 'X') ? 'O' : 'X';
    }

    // Check Winner
    void checkWinner() {
        // Rows & Columns
        for (int i = 0; i < 3; i++) {
            if (board[i][0] == board[i][1] &&
                board[i][1] == board[i][2] &&
                board[i][0] != ' ')
                winner = board[i][0];

            if (board[0][i] == board[1][i] &&
                board[1][i] == board[2][i] &&
                board[0][i] != ' ')
                winner = board[0][i];
        }

        // Diagonals
        if (board[0][0] == board[1][1] &&
            board[1][1] == board[2][2] &&
            board[0][0] != ' ')
            winner = board[0][0];

        if (board[0][2] == board[1][1] &&
            board[1][1] == board[2][0] &&
            board[0][2] != ' ')
            winner = board[0][2];
    }

    // Check Draw
    bool isDraw() {
        if (winner != ' ')
            return false;

        for (int i = 0; i < 3; i++)
            for (int j = 0; j < 3; j++)
                if (board[i][j] == ' ')
                    return false;

        return true;
    }

    // Play Game
    void play() {
        int row, col;

        while (true) {
            printBoard();
            cout << "Player " << turn << ", enter row and column (0-2): ";
            cin >> row >> col;

            if (!makeMove(row, col))
                continue;

            checkWinner();

            if (winner != ' ') {
                printBoard();
                cout << "🎉 Player " << winner << " wins!\n";
                break;
            }

            if (isDraw()) {
                printBoard();
                cout << "It's a draw!\n";
                break;
            }

            switchTurn();
        }
    }
};

int main() {
    Game game;
    game.play();
    return 0;
}
